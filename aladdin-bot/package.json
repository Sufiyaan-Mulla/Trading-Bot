{
  "name": "aladdin-trading-agent-backend",
  "version": "7.3.0",
  "description": "Secure backend proxy for Aladdin AI Trading Agent with WebSocket support",
  "main": "launch.js",
  "scripts": {
    "start": "node startup.js",
    "setup": "npm install",
    "launch": "node launch.js",
    "dev": "nodemon backend-server.js",
    "trade": "node trading-cli.js start",
    "trade:stop": "node trading-cli.js stop",
    "trade:status": "node trading-cli.js status",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart aladdin-trading",
    "pm2:logs": "pm2 logs aladdin-trading",
    "pm2:logs:nightly": "pm2 logs aladdin-nightly",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 list",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "backtest": "node backtest-historical.js",
    "backtest:full": "node backtest-full.js",
    "backtest:nightly": "node backtest-nightly.js",
    "backtest:nightly:asset": "node backtest-nightly.js --asset EUR_USD --capital 10000",
    "grid": "node grid-search-complete.js",
    "grid:quick": "node grid-search-complete.js --bars 200 --top 10",
    "grid:full": "node grid-search-complete.js --bars 1000 --top 20",
    "grid:csv": "node grid-search-complete.js --csv ./EURUSD_M5.csv --bars 5000 --top 20",
    "grid:legacy": "node grid-search.js",
    "test": "node test-suite.js",
    "logs": "tail -f trade_logs/engine.log",
    "logs:kills": "cat trade_logs/kill-log.json",
    "logs:shadow": "cat trade_logs/shadow-strategy.json",
    "logs:grid": "cat trade_logs/grid-results.json",
    "logs:nightly": "cat trade_logs/nightly-summary.csv",
    "logs:trades": "cat trade_logs/trades.json",
    "logs:summary": "cat trade_logs/summary.json",
    "safety:check": "node -e \"const {SAFETY}=require('./safety-constants');console.log(JSON.stringify(SAFETY,null,2))\"",
    "safety:reset": "node -e \"const fs=require('fs');const f='trade_logs/daily_lockout.json';if(fs.existsSync(f)){fs.unlinkSync(f);console.log('Lockout cleared');}else{console.log('No lockout active');}\"",
    "check": "node --check trading-engine.js && node --check backend-server.js && node --check backtest-nightly.js && node --check grid-search-complete.js && echo All files OK",
    "start:bare": "node backend-server.js",
    "pm2:logs:monitor": "pm2 logs aladdin-monitor",
    "pm2:logs:reset": "pm2 logs aladdin-reset",
    "pm2:logs:grid": "pm2 logs aladdin-grid",
    "logs:alerts": "cat trade_logs/alerts.json",
    "logs:grid:history": "cat trade_logs/grid-history.json",
    "logs:reset": "cat trade_logs/auto-reset.json",
    "auto:reset": "node auto-reset.js",
    "auto:grid": "node auto-grid.js --bars 1000"
  },
  "keywords": [
    "trading",
    "ai",
    "proxy",
    "anthropic",
    "claude",
    "websocket",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.20.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}