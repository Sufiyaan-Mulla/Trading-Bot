# Alpha Vantage
ALPHA_VANTAGE_API_KEY=YOUR_KEY_HERE

# OANDA (primary broker)
OANDA_API_KEY=YOUR_KEY_HERE
OANDA_ACCOUNT_ID=YOUR_ACCOUNT_ID
OANDA_ACCOUNT=YOUR_ACCOUNT_ID
OANDA_ENV=practice
OANDA_READONLY_KEY=YOUR_READONLY_KEY_HERE

# Hedge broker (optional secondary)
HEDGE_BROKER_URL=https://your-hedge-broker.com
HEDGE_API_KEY=YOUR_HEDGE_KEY_HERE

# Security / backup
BACKUP_KEY=YOUR_BACKUP_ENCRYPTION_KEY_HERE
AUDIT_HMAC_KEY=YOUR_AUDIT_HMAC_KEY_HERE
MAX_KEY_AGE_DAYS=90

# Notifications
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Dashboard / server
DASHBOARD_PORT=3000
DASHBOARD_ALLOWED_IPS=127.0.0.1,::1
HEALTH_PORT=9090

# Maintenance
BACKUP_INTERVAL_HOURS=24
