<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sufiyaan Bot</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
/* ── Variables ── */
:root {
  --bg0:#0d0d0d;
  --bg1:#141414;
  --bg2:#1c1c1c;
  --bg3:#242424;
  --border:#2a2a2a;
  --accent:#c8922a;
  --accent-dim:#a67520;
  --accent-glow:rgba(200,146,42,0.18);
  --orange:#EA580C;
  --gold-line:#F59E0B;
  --green:#22c55e;
  --red:#ef4444;
  --yellow:#eab308;
  --text:#e8e8e8;
  --text2:#888888;
  --text3:#444444;
  --mono:'JetBrains Mono','Cascadia Code',ui-monospace,monospace;
  --sans:'Inter',system-ui,-apple-system,sans-serif;
  --r:6px;
}

/* ── Reset ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--bg0);
  color:var(--text);
  font-family:var(--sans);
  font-size:13px;
  min-height:100vh;
  line-height:1.5;
  overflow-x:hidden;
}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg1)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--text3)}

/* ── Utilities ── */
.mono{font-family:var(--mono);font-variant-numeric:tabular-nums}
.dim{color:var(--text2)}

/* ══════════════════════════════════════
   NAVBAR
══════════════════════════════════════ */
#app-header {
  position:sticky;top:0;z-index:100;
  background:rgba(13,13,13,0.95);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  height:54px;
  display:flex;align-items:center;
  padding:0 20px;gap:16px;
}
#app-header::after{
  content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent-glow) 50%,transparent);
}

.nav-brand {
  font-size:16px;font-weight:800;letter-spacing:.04em;
  background:linear-gradient(90deg,var(--accent),var(--orange));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  flex-shrink:0;
}
.nav-meta {
  display:flex;align-items:center;gap:10px;
  font-size:11px;color:var(--text3);
  flex-shrink:0;
}
#hdr-asset{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--text2)}
#hdr-src{
  font-size:10px;background:var(--bg2);border:1px solid var(--border);
  border-radius:4px;padding:2px 6px;color:var(--text3);font-weight:600;letter-spacing:.06em;
}
#hdr-clock{font-family:var(--mono);font-size:11px;color:var(--text3)}

.nav-conn{display:flex;align-items:center;gap:5px;font-size:11px}
.conn-dot{width:7px;height:7px;border-radius:50%;background:var(--text3);transition:all .3s;flex-shrink:0}
.conn-dot.live{background:var(--green);box-shadow:0 0 6px rgba(34,197,94,.5);animation:pulse 2s ease-in-out infinite}
.conn-dot.err{background:var(--red)}
#conn-label{color:var(--text2)}

.nav-badges{display:flex;align-items:center;gap:8px;margin-left:auto;flex-shrink:0}

.status-pill{
  display:inline-flex;align-items:center;gap:5px;
  padding:4px 10px;border-radius:20px;
  font-size:10px;font-weight:700;letter-spacing:.1em;
  border:1px solid transparent;transition:all .3s;
}
.pill-running{background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.3);color:var(--green)}
.pill-halted{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.pill-backtest{background:rgba(200,146,42,.1);border-color:rgba(200,146,42,.3);color:var(--accent)}
.pill-dot{width:5px;height:5px;border-radius:50%;background:currentColor}
.pill-running .pill-dot{animation:pulse 1.4s ease-in-out infinite}

.mode-chip{
  font-size:10px;font-weight:700;letter-spacing:.1em;
  padding:3px 9px;border-radius:4px;
  background:var(--bg2);border:1px solid var(--border);color:var(--text3);
  transition:all .25s;
}
.mode-chip.live{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}

/* ══════════════════════════════════════
   PAGE WRAPPER
══════════════════════════════════════ */
.page{max-width:1560px;margin:0 auto;padding:18px 20px 30px;display:flex;flex-direction:column;gap:16px}

/* ══════════════════════════════════════
   STAT CARDS
══════════════════════════════════════ */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}

.stat-card{
  background:var(--bg1);border:1px solid var(--border);
  border-radius:var(--r);padding:14px 16px;
  position:relative;overflow:hidden;
  transition:border-color .2s,box-shadow .2s;
}
.stat-card:hover{border-color:rgba(200,146,42,.3);box-shadow:0 0 20px rgba(200,146,42,.08)}
.stat-card::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:var(--border);transition:background .3s;
}
.stat-card.gold::before{background:linear-gradient(180deg,var(--accent),var(--accent-dim))}
.stat-card.green::before{background:var(--green)}
.stat-card.red::before{background:var(--red)}

.stat-label{
  font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  color:var(--text3);margin-bottom:8px;
}
.stat-value{
  font-family:var(--mono);font-size:22px;font-weight:700;
  color:var(--text);line-height:1;letter-spacing:-.01em;
}
.stat-sub{font-size:11px;color:var(--text2);margin-top:4px}

/* ══════════════════════════════════════
   2-COLUMN LAYOUT
══════════════════════════════════════ */
.main-grid{display:grid;grid-template-columns:62% 1fr;gap:14px;align-items:start}

/* ── PANELS (shared) ── */
.panel{
  background:var(--bg1);border:1px solid var(--border);
  border-radius:var(--r);padding:14px 16px;
}
.panel-head{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:12px;
}
.panel-title{
  font-size:10px;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;color:var(--text2);
}

/* ══════════════════════════════════════
   EQUITY CHART
══════════════════════════════════════ */
#chart-panel{background:var(--bg1);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px}
.chart-canvas-wrap{position:relative;height:280px;margin-top:8px}
.chart-canvas-wrap canvas{position:absolute;inset:0;width:100%!important;height:100%!important}
#chart-meta{font-family:var(--mono);font-size:11px;color:var(--text3)}

/* ══════════════════════════════════════
   CONTROLS
══════════════════════════════════════ */
.ctrl-btns{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}

.btn{
  padding:9px 12px;border-radius:var(--r);border:1px solid transparent;
  cursor:pointer;font-size:12px;font-weight:700;letter-spacing:.04em;
  font-family:var(--sans);transition:all .18s;
  display:flex;align-items:center;justify-content:center;gap:6px;
}
.btn-start{
  background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.25);color:var(--green);
}
.btn-start:hover{background:rgba(34,197,94,.2);border-color:rgba(34,197,94,.4)}
.btn-stop{
  background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.22);color:var(--red);
}
.btn-stop:hover{background:rgba(239,68,68,.2);border-color:rgba(239,68,68,.38)}

.ctrl-row{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}
.ctrl-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);flex-shrink:0}

#pair-select{
  flex:1;min-width:0;
  background:var(--bg2);color:var(--text);border:1px solid var(--border);
  border-radius:var(--r);padding:6px 8px;
  font-size:12px;font-family:var(--sans);cursor:pointer;outline:none;
  transition:border-color .2s;
}
#pair-select:focus{border-color:var(--accent)}
#pair-select option{background:var(--bg2)}

/* Mode toggle */
.toggle-wrap{display:flex;align-items:center;gap:7px}
.toggle-lbl{font-size:11px;font-weight:700;letter-spacing:.06em;color:var(--text3);transition:color .2s}
.toggle-lbl.active{color:var(--text)}
#mode-toggle{
  width:38px;height:20px;border-radius:10px;border:none;
  background:var(--bg3);border:1px solid var(--border);
  position:relative;cursor:pointer;padding:0;
  transition:background .25s,border-color .25s;
}
#mode-toggle::after{
  content:'';position:absolute;top:2px;left:2px;
  width:14px;height:14px;border-radius:50%;
  background:var(--text3);transition:transform .22s,background .22s;
}
#mode-toggle.on{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.38)}
#mode-toggle.on::after{transform:translateX(18px);background:var(--red)}

.btn-gold{
  width:100%;padding:9px 12px;
  background:rgba(200,146,42,.1);border:1px solid rgba(200,146,42,.25);color:var(--accent);
  border-radius:var(--r);cursor:pointer;
  font-size:12px;font-weight:700;letter-spacing:.04em;font-family:var(--sans);
  transition:all .18s;
}
.btn-gold:hover{background:rgba(200,146,42,.2);border-color:rgba(200,146,42,.42)}
.btn-gold.running{opacity:.45;cursor:not-allowed;pointer-events:none}

#ctrl-msg{min-height:14px;font-size:11px;color:var(--text2);text-align:center;margin-top:6px}

/* ══════════════════════════════════════
   POSITION PANEL
══════════════════════════════════════ */
.pos-badge{
  padding:3px 8px;border-radius:4px;font-size:10px;font-weight:700;
  letter-spacing:.08em;border:1px solid transparent;
}
.pos-none{background:var(--bg2);border-color:var(--border);color:var(--text3)}
.pos-long{background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.3);color:var(--green)}
.pos-short{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.pos-empty-wrap{padding:20px 0;text-align:center;color:var(--text3);font-size:12px}

/* ══════════════════════════════════════
   BACKTEST
══════════════════════════════════════ */
#bt-meta{font-family:var(--mono);font-size:11px;color:var(--text3)}
.bt-spinner{
  width:28px;height:28px;border-radius:50%;
  border:3px solid var(--bg3);border-top-color:var(--accent);
  animation:spin .75s linear infinite;margin:0 auto 8px;
}
.bt-run-lbl{font-size:12px;color:var(--text2);text-align:center}
.bt-results-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:2px}
.bt-stat{background:var(--bg2);border-radius:var(--r);padding:10px 12px;text-align:center}
.bt-stat-k{font-size:9px;font-weight:700;letter-spacing:.11em;text-transform:uppercase;color:var(--text3);margin-bottom:4px}
.bt-stat-v{font-family:var(--mono);font-size:17px;font-weight:700;color:var(--text)}

/* ══════════════════════════════════════
   TRADES TABLE
══════════════════════════════════════ */
#trades-meta{font-family:var(--mono);font-size:11px;color:var(--text3)}
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:260px;margin-top:8px}
.data-tbl{width:100%;border-collapse:collapse;font-size:12px}
.data-tbl th{
  font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  color:var(--text3);padding:6px 8px;text-align:left;white-space:nowrap;
  border-bottom:1px solid var(--border);
  background:var(--bg1);position:sticky;top:0;z-index:1;
}
.data-tbl td{
  padding:6px 8px;border-bottom:1px solid rgba(42,42,42,.5);
  font-family:var(--mono);font-size:12px;color:var(--text2);white-space:nowrap;
}
.data-tbl tr:last-child td{border-bottom:none}
.data-tbl tbody tr:hover td{background:var(--bg2);color:var(--text)}
.empty-cell{text-align:center!important;color:var(--text3)!important;font-family:var(--sans)!important;padding:20px!important}
.t-win{color:var(--green)!important}
.t-loss{color:var(--red)!important}
.result-win{
  display:inline-block;padding:1px 6px;border-radius:3px;
  font-size:10px;font-weight:700;font-family:var(--sans);
  background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.25);color:var(--green);
}
.result-loss{
  display:inline-block;padding:1px 6px;border-radius:3px;
  font-size:10px;font-weight:700;font-family:var(--sans);
  background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.22);color:var(--red);
}

/* ══════════════════════════════════════
   AI CONFIDENCE
══════════════════════════════════════ */
.conf-big{font-family:var(--mono);font-size:38px;font-weight:800;line-height:1;color:var(--accent)}
.signal-badge{
  padding:3px 9px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:.07em;
  border:1px solid transparent;
}
.sig-buy{background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.3);color:var(--green)}
.sig-sell{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.sig-none{background:var(--bg2);border-color:var(--border);color:var(--text3)}

.conf-bar-track{height:8px;background:var(--bg2);border-radius:4px;overflow:hidden;margin:10px 0 4px}
#conf-bar{height:100%;border-radius:4px;width:0%;background:var(--accent);transition:width .55s ease,background .4s}
.conf-axis{display:flex;justify-content:space-between;font-size:9px;color:var(--text3);font-family:var(--mono);margin-bottom:10px}

.ml-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;border-top:1px solid var(--border);padding-top:10px}
.ml-cell{}
.ml-k{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:2px}
.ml-v{font-family:var(--mono);font-size:12px;color:var(--text2)}

/* ══════════════════════════════════════
   LIVE PRICES
══════════════════════════════════════ */
#prices-row{display:flex;flex-direction:column;gap:6px}
.price-card{
  display:flex;align-items:center;justify-content:space-between;
  padding:9px 12px;background:var(--bg2);border-radius:var(--r);
  border:1px solid var(--border);transition:border-color .25s;
}
.price-card.active-pair{border-color:rgba(200,146,42,.4);background:rgba(200,146,42,.04)}
.price-pair-lbl{font-size:11px;font-weight:700;letter-spacing:.08em;color:var(--text2);min-width:62px}
.price-val{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--text);transition:color .4s;font-variant-numeric:tabular-nums}
.price-change{font-size:10px;font-family:var(--mono);color:var(--text3);display:flex;align-items:center;gap:3px;min-width:80px;justify-content:flex-end}
.price-change.up{color:var(--green)}
.price-change.down{color:var(--red)}
.price-arrow{font-size:9px}
.price-source{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;min-width:40px;text-align:right}

/* ══════════════════════════════════════
   RISK PANEL
══════════════════════════════════════ */
.risk-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:3px}
.risk-k{font-size:11px;color:var(--text2)}
.risk-v{font-family:var(--mono);font-size:12px;color:var(--text)}
.risk-bar-track{height:5px;background:var(--bg2);border-radius:3px;overflow:hidden;margin:4px 0 2px}
.risk-bar-fill{height:100%;border-radius:3px;transition:width .6s ease,background .4s}
.risk-marks{display:flex;justify-content:space-between;font-size:9px;color:var(--text3);font-family:var(--mono);margin-bottom:8px}
.risk-section{font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--text3);margin:10px 0 6px}
.risk-section:first-child{margin-top:0}

.cb-badge{
  padding:3px 8px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:.08em;
  border:1px solid transparent;
}
.cb-ok{background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.28);color:var(--green)}
.cb-warn{background:rgba(234,179,8,.1);border-color:rgba(234,179,8,.28);color:var(--yellow)}
.cb-halt{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}

/* ══════════════════════════════════════
   FOOTER
══════════════════════════════════════ */
footer{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 20px;border-top:1px solid var(--border);
  background:var(--bg1);font-size:11px;color:var(--text3);
}
#footer-ts{font-family:var(--mono)}

/* ══════════════════════════════════════
   ANIMATIONS
══════════════════════════════════════ */
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
@keyframes spin{to{transform:rotate(360deg)}}

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@media(max-width:1080px){
  .main-grid{grid-template-columns:1fr}
}
@media(max-width:720px){
  .stats-row{grid-template-columns:1fr 1fr}
  #prices-row{display:grid;grid-template-columns:1fr 1fr}
}
@media(max-width:480px){
  .stats-row{grid-template-columns:1fr}
  .page{padding:10px}
  #app-header{padding:0 12px}
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════
     NAVBAR
══════════════════════════════════════ -->
<nav id="app-header">
  <span class="nav-brand">Sufiyaan Bot</span>

  <div class="nav-meta">
    <span id="hdr-asset">—</span>
    <span id="hdr-src">—</span>
    <span id="hdr-clock" class="mono">—</span>
    <div class="nav-conn">
      <span id="conn-dot" class="conn-dot"></span>
      <span id="conn-label">Connecting…</span>
    </div>
  </div>

  <div class="nav-badges">
    <div id="run-status" class="status-pill pill-running">
      <span class="pill-dot"></span>
      <span id="run-label">RUNNING</span>
    </div>
    <div id="mode-chip" class="mode-chip">PAPER MODE</div>
  </div>
</nav>

<!-- ══════════════════════════════════════
     PAGE
══════════════════════════════════════ -->
<div class="page">

  <!-- ── STAT CARDS ── -->
  <div class="stats-row">

    <div class="stat-card gold" id="sc-capital">
      <div class="stat-label">Capital</div>
      <div class="stat-value mono" id="s-capital">—</div>
      <div class="stat-sub" id="s-return">—</div>
    </div>

    <div class="stat-card" id="sc-pnl">
      <div class="stat-label">Daily P&amp;L</div>
      <div class="stat-value mono" id="s-pnl">—</div>
      <div class="stat-sub" id="s-pnl-sub">vs session open</div>
    </div>

    <div class="stat-card" id="sc-wr">
      <div class="stat-label">Win Rate</div>
      <div class="stat-value mono" id="s-wr">—</div>
      <div class="stat-sub" id="s-wr-sub">—</div>
    </div>

    <div class="stat-card gold" id="sc-trades">
      <div class="stat-label">Trades</div>
      <div class="stat-value mono" id="s-trades">—</div>
      <div class="stat-sub" id="s-trades-sub">—</div>
    </div>

  </div><!-- /stats-row -->

  <!-- ── 2-COLUMN GRID ── -->
  <div class="main-grid">

    <!-- ════════════ LEFT COLUMN ════════════ -->
    <div class="left-col" style="display:flex;flex-direction:column;gap:14px">

      <!-- Chart -->
      <div id="chart-panel">
        <div class="panel-head">
          <span class="panel-title">Equity Curve</span>
          <span id="chart-meta" class="dim">Waiting for data…</span>
        </div>
        <div class="chart-canvas-wrap">
          <canvas id="equityChart"></canvas>
        </div>
      </div>

      <!-- Controls -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Trading Controls</span>
          <span id="ctrl-msg" class="dim"></span>
        </div>

        <div class="ctrl-btns">
          <button id="btn-start" class="btn btn-start">▶ Start Trading</button>
          <button id="btn-stop"  class="btn btn-stop">■ Stop Trading</button>
        </div>

        <div class="ctrl-row">
          <span class="ctrl-label">Pair</span>
          <select id="pair-select">
            <option value="EURUSD">EUR / USD</option>
            <option value="GBPUSD">GBP / USD</option>
            <option value="USDJPY">USD / JPY</option>
            <option value="AUDUSD">AUD / USD</option>
          </select>
        </div>

        <div class="ctrl-row" style="margin-bottom:10px">
          <span class="ctrl-label">Mode</span>
          <div class="toggle-wrap">
            <span id="lbl-paper" class="toggle-lbl active">PAPER</span>
            <button id="mode-toggle" role="switch" aria-checked="false"></button>
            <span id="lbl-live" class="toggle-lbl">LIVE</span>
          </div>
        </div>

        <button id="btn-backtest" class="btn-gold">⊙ Run Backtest</button>
      </div><!-- /controls -->

      <!-- Open Position -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Open Position</span>
          <span id="pos-badge" class="pos-badge pos-none">No Position</span>
        </div>
        <div id="pos-empty" class="pos-empty-wrap">No open position</div>
        <div id="pos-content" style="display:none">
          <div class="tbl-scroll" style="max-height:100px">
            <table class="data-tbl">
              <thead><tr>
                <th>Pair</th><th>Dir</th><th>Entry</th><th>Current</th>
                <th>Stop</th><th>Target</th><th>Unreal P&amp;L</th><th>Conf</th>
              </tr></thead>
              <tbody id="pos-body"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Backtest Panel -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Backtest</span>
          <span id="bt-meta" class="dim">Ready</span>
        </div>
        <div id="bt-idle">
          <button id="bt-btn" class="btn-gold">⊙ Run Full Backtest</button>
        </div>
        <div id="bt-running" style="display:none;padding:14px 0">
          <div class="bt-spinner"></div>
          <div class="bt-run-lbl">Running simulation…</div>
        </div>
        <div id="bt-results" style="display:none">
          <div class="bt-results-grid">
            <div class="bt-stat">
              <div class="bt-stat-k">Return</div>
              <div class="bt-stat-v mono" id="bt-return">—</div>
            </div>
            <div class="bt-stat">
              <div class="bt-stat-k">Win Rate</div>
              <div class="bt-stat-v mono" id="bt-wr">—</div>
            </div>
            <div class="bt-stat">
              <div class="bt-stat-k">Sharpe</div>
              <div class="bt-stat-v mono" id="bt-sharpe">—</div>
            </div>
            <div class="bt-stat">
              <div class="bt-stat-k">Max DD</div>
              <div class="bt-stat-v mono" id="bt-dd">—</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Trades -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Recent Trades</span>
          <span id="trades-meta" class="dim">—</span>
        </div>
        <div class="tbl-scroll">
          <table class="data-tbl">
            <thead><tr>
              <th>#</th><th>Pair</th><th>Dir</th><th>Entry</th><th>Exit</th>
              <th>P&amp;L</th><th>%</th><th>Conf</th><th>Result</th><th>Dur</th>
            </tr></thead>
            <tbody id="trades-body"></tbody>
          </table>
        </div>
      </div>

    </div><!-- /left-col -->

    <!-- ════════════ RIGHT COLUMN ════════════ -->
    <div class="right-col" style="display:flex;flex-direction:column;gap:14px">

      <!-- AI Confidence -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">AI Confidence</span>
          <span id="ml-signal" class="signal-badge sig-none">—</span>
        </div>

        <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:2px">
          <span id="conf-pct" class="conf-big">—</span>
          <span id="conf-lbl" style="font-size:11px;color:var(--text2)">No prediction</span>
        </div>

        <div class="conf-bar-track">
          <div id="conf-bar" style="width:0%;background:var(--accent)"></div>
        </div>
        <div class="conf-axis"><span>0%</span><span>50%</span><span>100%</span></div>

        <div class="ml-grid">
          <div class="ml-cell">
            <div class="ml-k">Mode</div>
            <div class="ml-v" id="ml-mode">—</div>
          </div>
          <div class="ml-cell">
            <div class="ml-k">OOS Accuracy</div>
            <div class="ml-v" id="ml-oos">—</div>
          </div>
          <div class="ml-cell">
            <div class="ml-k">Sharpe</div>
            <div class="ml-v" id="ml-sharpe">—</div>
          </div>
          <div class="ml-cell">
            <div class="ml-k">Profit Factor</div>
            <div class="ml-v" id="ml-pf">—</div>
          </div>
        </div>
      </div>

      <!-- Live Prices -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Live Prices</span>
        </div>
        <div id="prices-row">

          <div class="price-card" id="pc-EURUSD">
            <span class="price-pair-lbl">EUR/USD</span>
            <span class="price-val mono" id="pv-EURUSD">—</span>
            <span class="price-change flat" id="pdelta-EURUSD">
              <span class="price-arrow">→</span><span>—</span>
            </span>
            <span class="price-source" id="psrc-EURUSD">—</span>
          </div>

          <div class="price-card" id="pc-GBPUSD">
            <span class="price-pair-lbl">GBP/USD</span>
            <span class="price-val mono" id="pv-GBPUSD">—</span>
            <span class="price-change flat" id="pdelta-GBPUSD">
              <span class="price-arrow">→</span><span>—</span>
            </span>
            <span class="price-source" id="psrc-GBPUSD">—</span>
          </div>

          <div class="price-card" id="pc-USDJPY">
            <span class="price-pair-lbl">USD/JPY</span>
            <span class="price-val mono" id="pv-USDJPY">—</span>
            <span class="price-change flat" id="pdelta-USDJPY">
              <span class="price-arrow">→</span><span>—</span>
            </span>
            <span class="price-source" id="psrc-USDJPY">—</span>
          </div>

          <div class="price-card" id="pc-AUDUSD">
            <span class="price-pair-lbl">AUD/USD</span>
            <span class="price-val mono" id="pv-AUDUSD">—</span>
            <span class="price-change flat" id="pdelta-AUDUSD">
              <span class="price-arrow">→</span><span>—</span>
            </span>
            <span class="price-source" id="psrc-AUDUSD">—</span>
          </div>

        </div>
      </div><!-- /prices -->

      <!-- Risk Status -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Risk Status</span>
          <span id="cb-badge" class="cb-badge cb-ok">CB: OK</span>
        </div>

        <div class="risk-section">Daily Loss</div>
        <div class="risk-row">
          <span class="risk-k">Loss today</span>
          <span class="risk-v" id="r-daily">0.00%</span>
        </div>
        <div class="risk-bar-track">
          <div id="r-daily-bar" class="risk-bar-fill" style="width:0%;background:var(--green)"></div>
        </div>
        <div class="risk-marks"><span>0%</span><span>3.5%</span><span>7%</span></div>

        <div class="risk-section">Drawdown</div>
        <div class="risk-row">
          <span class="risk-k">Max drawdown</span>
          <span class="risk-v" id="r-dd">0.00%</span>
        </div>
        <div class="risk-bar-track">
          <div id="r-dd-bar" class="risk-bar-fill" style="width:0%;background:var(--green)"></div>
        </div>
        <div class="risk-marks"><span>0%</span><span>10%</span><span>20%</span></div>

        <div class="risk-section">Status</div>
        <div class="risk-row"><span class="risk-k">Circuit breaker</span><span class="risk-v" id="r-cb">—</span></div>
        <div class="risk-row"><span class="risk-k">Market regime</span><span class="risk-v" id="r-regime">—</span></div>
        <div class="risk-row"><span class="risk-k">Peak capital</span><span class="risk-v" id="r-peak">—</span></div>
        <div class="risk-row"><span class="risk-k">Spread</span><span class="risk-v" id="r-spread">—</span></div>
        <div class="risk-row"><span class="risk-k">Drift</span><span class="risk-v" id="r-drift">—</span></div>

      </div><!-- /risk -->

    </div><!-- /right-col -->
  </div><!-- /main-grid -->

</div><!-- /page -->

<footer>
  <span>Sufiyaan Bot &copy; 2025</span>
  <span id="footer-ts" class="mono">—</span>
</footer>

<!-- ══════════════════════════════════════
     JAVASCRIPT  (WebSocket logic preserved exactly)
══════════════════════════════════════ -->
<script>
'use strict';

/* ── Helpers ── */
const $   = id => document.getElementById(id);
const fn  = (n, d=2) => n == null || isNaN(Number(n)) ? '—' : Number(n).toFixed(d);
const fd  = n => n == null ? '—' : (Number(n) < 0 ? '-$' : '$') + Math.abs(Number(n)).toFixed(2);
const fp  = (n, d=2) => n == null ? '—' : fn(n, d) + '%';
const clr = v => Number(v) > 0 ? 'var(--green)' : Number(v) < 0 ? 'var(--red)' : 'var(--text2)';

const PAIRS   = ['EURUSD','GBPUSD','USDJPY','AUDUSD'];
const JYDP    = { USDJPY: 3 };
const pdp     = pair => JYDP[pair] || 5;

/* ── State ── */
const priceCache = {};
const equityData = [];
let equityChart  = null;
let ws, reconnTimer;
let isLiveMode   = false;
let wasBacktest  = false;
let btSnapshot   = null;

/* ════════════════════════════════════════════════════════════
   CHART
════════════════════════════════════════════════════════════ */
function initChart() {
  const ctx  = $('equityChart').getContext('2d');
  const grad = ctx.createLinearGradient(0, 0, 0, 280);
  grad.addColorStop(0, 'rgba(245,158,11,0.38)');
  grad.addColorStop(1, 'rgba(245,158,11,0.00)');

  equityChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: [],
      datasets: [{
        data: [],
        borderColor: '#F59E0B',
        backgroundColor: grad,
        borderWidth: 2,
        fill: true,
        tension: 0.4,
        pointRadius: 0,
        pointHoverRadius: 5,
        pointHoverBackgroundColor: '#F59E0B',
        pointHoverBorderColor: '#0d0d0d',
        pointHoverBorderWidth: 2,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 350 },
      interaction: { intersect: false, mode: 'index' },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1c1c1c',
          borderColor: 'rgba(200,146,42,0.3)',
          borderWidth: 1,
          titleColor: '#888888',
          bodyColor: '#e8e8e8',
          padding: 10,
          callbacks: {
            label: c => '  $' + Number(c.parsed.y).toFixed(2),
          }
        }
      },
      scales: {
        x: {
          ticks: {
            color: '#444444', maxTicksLimit: 8,
            font: { family: 'JetBrains Mono, monospace', size: 10 },
          },
          grid: { color: 'rgba(42,42,42,0.8)' },
          border: { color: 'rgba(42,42,42,0.5)' },
        },
        y: {
          ticks: {
            color: '#444444',
            font: { family: 'JetBrains Mono, monospace', size: 10 },
            callback: v => '$' + Number(v).toFixed(0),
          },
          grid: { color: 'rgba(42,42,42,0.8)' },
          border: { color: 'rgba(42,42,42,0.5)' },
        }
      }
    }
  });
}

function pushEquityPoint(value, ts) {
  if (value == null || isNaN(value)) return;
  const label = new Date(ts || Date.now()).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  equityData.push({ value, label });
  if (equityData.length > 200) equityData.shift();
  if (!equityChart) return;

  equityChart.data.labels                    = equityData.map(p => p.label);
  equityChart.data.datasets[0].data          = equityData.map(p => p.value);

  const first = equityData[0]?.value;
  const last  = equityData[equityData.length - 1]?.value;
  const rising = (last != null && first != null && last >= first);
  const color  = rising ? '#F59E0B' : '#EF4444';

  equityChart.data.datasets[0].borderColor = color;
  const ctx  = $('equityChart').getContext('2d');
  const grad = ctx.createLinearGradient(0, 0, 0, 280);
  grad.addColorStop(0, color + '60');
  grad.addColorStop(1, color + '00');
  equityChart.data.datasets[0].backgroundColor = grad;

  equityChart.update('none');
  $('chart-meta').textContent = equityData.length + ' points';
}

/* ════════════════════════════════════════════════════════════
   UPDATE — HEADER
════════════════════════════════════════════════════════════ */
function updateHeader(d) {
  const halted = d.halted || (d.drift && d.drift.halted);
  const pill   = $('run-status');
  const lbl    = $('run-label');

  if (d.backtestMode) {
    pill.className  = 'status-pill pill-backtest';
    lbl.textContent = 'BACKTEST';
  } else if (halted) {
    pill.className  = 'status-pill pill-halted';
    lbl.textContent = 'HALTED';
  } else {
    pill.className  = 'status-pill pill-running';
    lbl.textContent = 'RUNNING';
  }

  const src   = (d.priceSource || '').toLowerCase();
  const paper = src === 'seed' || src === 'simulation' || src === 'seed_no_api' || src === 'cached' || !!d.backtestMode;
  $('mode-chip').textContent = paper ? 'PAPER' : 'LIVE';
  $('mode-chip').className   = paper ? 'mode-chip' : 'mode-chip live';

  $('hdr-asset').textContent = d.asset ? d.asset.replace(/(\w{3})(\w+)/, '$1/$2') : '—';
  $('hdr-src').textContent   = d.priceSource || '—';
  $('footer-ts').textContent = 'Last tick: ' + new Date(d.ts || Date.now()).toLocaleTimeString();
}

/* ════════════════════════════════════════════════════════════
   UPDATE — STATS
════════════════════════════════════════════════════════════ */
function updateStats(d) {
  const cap = Number(d.capital  || 0);
  const ini = Number(d.initialCapital || 10000);
  const ret = ini > 0 ? (cap - ini) / ini * 100 : 0;

  $('s-capital').textContent = '$' + cap.toFixed(2);
  $('s-capital').style.color = cap >= ini ? 'var(--green)' : 'var(--red)';
  $('s-return').textContent  = (ret >= 0 ? '+' : '') + ret.toFixed(2) + '% total return';
  $('s-return').style.color  = ret >= 0 ? 'var(--green)' : 'var(--red)';
  $('sc-capital').className  = 'stat-card ' + (cap >= ini ? 'gold' : 'red');

  const pnl = Number(d.dailyPnl || 0);
  $('s-pnl').textContent  = fd(pnl);
  $('s-pnl').style.color  = clr(pnl);
  $('sc-pnl').className   = 'stat-card ' + (pnl >= 0 ? 'green' : 'red');

  const m  = d.metrics || {};
  const wr = m.winRate;
  $('s-wr').textContent   = wr != null ? fn(wr, 1) + '%' : '—%';
  $('s-wr').style.color   = wr > 55 ? 'var(--green)' : wr > 40 ? 'var(--yellow)' : wr != null ? 'var(--red)' : 'var(--text2)';
  $('s-wr-sub').textContent = (m.trades || 0) + ' trades';

  $('s-trades').textContent     = m.trades != null ? String(m.trades) : '—';
  $('s-trades').style.color     = 'var(--accent)';
  $('s-trades-sub').textContent = m.wins != null ? 'W/L: ' + m.wins + '/' + m.losses : '—';
  $('sc-trades').className      = 'stat-card gold';
}

/* ════════════════════════════════════════════════════════════
   UPDATE — PRICES
════════════════════════════════════════════════════════════ */
function updatePrices(d) {
  if (!d.asset || !d.marketPrice) return;
  const asset = d.asset;
  const now   = Number(d.marketPrice);
  const prev  = priceCache[asset] ? priceCache[asset].price : null;
  priceCache[asset] = { price: now, source: d.priceSource };

  PAIRS.forEach(p => {
    const card = $('pc-' + p);
    if (card) card.classList.toggle('active-pair', p === asset);
  });

  const valEl   = $('pv-'     + asset);
  const deltaEl = $('pdelta-' + asset);
  const srcEl   = $('psrc-'   + asset);
  if (!valEl) return;

  const dp = pdp(asset);
  valEl.textContent = now.toFixed(dp);

  if (prev != null && prev !== now) {
    const diff = now - prev;
    const pct  = (diff / prev * 100).toFixed(4);
    const up   = diff > 0;
    deltaEl.className = 'price-change ' + (up ? 'up' : 'down');
    deltaEl.innerHTML = '<span class="price-arrow">' + (up ? '▲' : '▼') + '</span>'
      + '<span>' + (up ? '+' : '') + diff.toFixed(dp) + ' (' + (up ? '+' : '') + pct + '%)</span>';
    valEl.style.color = up ? 'var(--green)' : 'var(--red)';
    setTimeout(() => { valEl.style.color = ''; }, 1400);
  } else if (prev == null) {
    deltaEl.className = 'price-change flat';
    deltaEl.innerHTML = '<span class="price-arrow">→</span><span>Loading…</span>';
  }

  if (srcEl) srcEl.textContent = d.priceSource || '—';
}

/* ════════════════════════════════════════════════════════════
   UPDATE — ML CONFIDENCE
════════════════════════════════════════════════════════════ */
function updateConfidence(d) {
  const score  = d.mlConfidenceScore;
  const signal = d.mlSignal;
  const sigEl  = $('ml-signal');

  if (score != null) {
    const hi  = score > 70;
    const med = score > 50;
    const col = hi ? 'var(--green)' : med ? 'var(--yellow)' : 'var(--red)';
    $('conf-pct').textContent       = fn(score, 1) + '%';
    $('conf-pct').style.color       = col;
    $('conf-bar').style.width       = Math.min(100, score) + '%';
    $('conf-bar').style.background  = col;
    $('conf-lbl').textContent       = hi ? 'High confidence' : med ? 'Moderate' : 'Low confidence';
    $('conf-lbl').style.color       = col;
  } else {
    $('conf-pct').textContent       = '—';
    $('conf-pct').style.color       = 'var(--text2)';
    $('conf-bar').style.width       = '0%';
    $('conf-bar').style.background  = 'var(--text3)';
    $('conf-lbl').textContent       = 'No prediction';
    $('conf-lbl').style.color       = 'var(--text2)';
  }

  if (signal === 'BUY') {
    sigEl.className  = 'signal-badge sig-buy';
    sigEl.textContent = '▲ BUY';
  } else if (signal === 'SELL') {
    sigEl.className  = 'signal-badge sig-sell';
    sigEl.textContent = '▼ SELL';
  } else {
    sigEl.className  = 'signal-badge sig-none';
    sigEl.textContent = signal || '—';
  }

  const m   = d.metrics || {};
  const oos = d.mlOOS   || {};
  $('ml-mode').textContent   = d.backtestMode ? 'BACKTEST' : 'LIVE';
  $('ml-sharpe').textContent = m.sharpe   != null ? fn(m.sharpe,   3) : '—';
  $('ml-pf').textContent     = m.pf       != null ? fn(m.pf,       3) : '—';
  $('ml-oos').textContent    = oos.accuracy != null ? oos.accuracy + '% (' + (oos.grade || '?') + ')' : '—';
}

/* ════════════════════════════════════════════════════════════
   UPDATE — POSITION
════════════════════════════════════════════════════════════ */
function updatePosition(d) {
  const pos   = d.position;
  const badge = $('pos-badge');

  if (!pos) {
    badge.className   = 'pos-badge pos-none';
    badge.textContent = 'No Position';
    $('pos-empty').style.display   = '';
    $('pos-content').style.display = 'none';
    return;
  }

  const isShort = pos.side === 'SHORT';
  badge.className   = 'pos-badge ' + (isShort ? 'pos-short' : 'pos-long');
  badge.textContent = isShort ? '▼ SHORT' : '▲ LONG';
  $('pos-empty').style.display   = 'none';
  $('pos-content').style.display = '';

  const asset  = d.asset  || pos.asset || '—';
  const cur    = Number(d.marketPrice || 0);
  const entry  = Number(pos.entry  || 0);
  const shares = Number(pos.shares || 0);
  const upnl   = isShort ? shares * (entry - cur) : shares * (cur - entry);
  const dp     = pdp(asset);

  $('pos-body').innerHTML = `<tr>
    <td>${asset}</td>
    <td style="color:${isShort ? 'var(--red)' : 'var(--green)'};font-weight:700">${isShort ? '▼ SHORT' : '▲ LONG'}</td>
    <td>${fn(entry, dp)}</td>
    <td>${fn(cur, dp)}</td>
    <td>${fn(pos.stopLoss,   dp)}</td>
    <td>${fn(pos.takeProfit, dp)}</td>
    <td style="color:${clr(upnl)};font-weight:700">${fd(upnl)}</td>
    <td>${pos.confidence ? pos.confidence + '%' : '—'}</td>
  </tr>`;
}

/* ════════════════════════════════════════════════════════════
   UPDATE — RISK
════════════════════════════════════════════════════════════ */
function updateRisk(d) {
  const ini      = Number(d.initialCapital || 10000);
  const cap      = Number(d.capital || ini);
  const daily    = cap - Number(d.dailyStartCapital || ini);
  const dailyPct = ini > 0 ? Math.abs(Math.min(0, daily)) / ini * 100 : 0;
  const dd       = Number(d.maxDrawdown || (d.metrics && d.metrics.maxDrawdown) || 0);

  const dailyCol = dailyPct > 5 ? 'var(--red)' : dailyPct > 2.5 ? 'var(--yellow)' : 'var(--green)';
  $('r-daily').textContent         = fp(dailyPct, 2);
  $('r-daily').style.color         = dailyCol;
  $('r-daily-bar').style.width     = Math.min(100, dailyPct / 7 * 100) + '%';
  $('r-daily-bar').style.background = dailyCol;

  const ddCol = dd > 15 ? 'var(--red)' : dd > 8 ? 'var(--yellow)' : 'var(--green)';
  $('r-dd').textContent         = fp(dd, 2);
  $('r-dd').style.color         = ddCol;
  $('r-dd-bar').style.width     = Math.min(100, dd / 20 * 100) + '%';
  $('r-dd-bar').style.background = ddCol;

  const cbEl  = $('cb-badge');
  const cbMsg = $('r-cb');
  const driftHalted = d.drift && d.drift.halted;
  if (driftHalted || d.halted) {
    cbEl.className  = 'cb-badge cb-halt'; cbEl.textContent = 'CB: TRIPPED';
    cbMsg.textContent = 'HALTED'; cbMsg.style.color = 'var(--red)';
  } else if (dailyPct > 5 || dd > 15) {
    cbEl.className  = 'cb-badge cb-warn'; cbEl.textContent = 'CB: WARNING';
    cbMsg.textContent = 'WARNING'; cbMsg.style.color = 'var(--yellow)';
  } else {
    cbEl.className  = 'cb-badge cb-ok';  cbEl.textContent = 'CB: OK';
    cbMsg.textContent = 'Normal'; cbMsg.style.color = 'var(--green)';
  }

  $('r-regime').textContent = d.marketRegime || '—';
  $('r-peak').textContent   = d.peakCapital != null ? '$' + Number(d.peakCapital).toFixed(2) : '—';
  const sp = d.spread || {};
  $('r-spread').textContent = sp.pips != null ? fn(sp.pips, 2) + ' pips' : '—';

  const drift = d.drift || {};
  $('r-drift').textContent  = drift.halted ? 'HALTED' : drift.active ? 'Monitoring' : 'Inactive';
  $('r-drift').style.color  = drift.halted ? 'var(--red)' : drift.active ? 'var(--green)' : 'var(--text2)';
}

/* ════════════════════════════════════════════════════════════
   UPDATE — TRADES
════════════════════════════════════════════════════════════ */
function updateTrades(d) {
  const trades = d.recentTrades || [];
  const tbody  = $('trades-body');
  $('trades-meta').textContent = 'Last ' + Math.min(10, trades.length);

  if (!trades.length) {
    tbody.innerHTML = '<tr><td colspan="10" class="empty-cell">No trades recorded yet</td></tr>';
    return;
  }

  const rows = trades.slice(-10).reverse();
  tbody.innerHTML = rows.map((t, i) => {
    const win     = t.profit > 0;
    const dur     = t.duration ? Math.round(t.duration / 60000) + 'm' : '—';
    const dp      = pdp(t.asset || 'EURUSD');
    const isShort = t.side === 'SHORT' || (t.entry > t.exit && t.profit > 0);
    return `<tr>
      <td class="dim">${rows.length - i}</td>
      <td>${t.asset || '—'}</td>
      <td style="color:${isShort ? 'var(--red)' : 'var(--green)'}">${isShort ? '▼ SHORT' : '▲ LONG'}</td>
      <td>${fn(t.entry, dp)}</td>
      <td>${fn(t.exit,  dp)}</td>
      <td class="${win ? 't-win' : 't-loss'}">${win ? '+' : ''}${fd(t.profit)}</td>
      <td class="${win ? 't-win' : 't-loss'}">${t.profitPercent != null ? (t.profitPercent > 0 ? '+' : '') + fn(t.profitPercent, 2) + '%' : '—'}</td>
      <td>${t.confidence ? t.confidence + '%' : '—'}</td>
      <td><span class="result-${win ? 'win' : 'loss'}">${win ? '✓ WIN' : '✗ LOSS'}</span></td>
      <td class="dim">${dur}</td>
    </tr>`;
  }).join('');
}

/* ════════════════════════════════════════════════════════════
   UPDATE — BACKTEST
════════════════════════════════════════════════════════════ */
function updateBacktest(d) {
  const running      = d.backtestMode === true;
  const justFinished = wasBacktest && !running;
  wasBacktest = running;

  $('bt-meta').textContent      = running ? 'Running…' : 'Ready';
  $('bt-idle').style.display    = (!running && !justFinished && !btSnapshot) ? '' : 'none';
  $('bt-running').style.display = running ? '' : 'none';
  $('bt-results').style.display = (!running && btSnapshot) ? '' : 'none';

  if (justFinished) {
    btSnapshot = d;
    $('bt-results').style.display = '';
    const m   = d.metrics || {};
    const ini = Number(d.initialCapital || 10000);
    const cap = Number(d.capital || ini);
    const ret = ini > 0 ? (cap - ini) / ini * 100 : 0;
    $('bt-return').textContent = (ret >= 0 ? '+' : '') + fn(ret, 2) + '%';
    $('bt-return').style.color = clr(ret);
    $('bt-wr').textContent     = m.winRate    != null ? fn(m.winRate,    1) + '%' : '—';
    $('bt-sharpe').textContent = m.sharpe     != null ? fn(m.sharpe,     3)       : '—';
    $('bt-dd').textContent     = m.maxDrawdown != null ? fn(m.maxDrawdown, 2) + '%' : '—';
  }

  $('btn-backtest').classList.toggle('running', running);
  $('bt-btn').classList.toggle('running', running);
}

/* ════════════════════════════════════════════════════════════
   MASTER UPDATE
════════════════════════════════════════════════════════════ */
function update(d) {
  updateHeader(d);
  updateStats(d);
  updatePrices(d);
  updateConfidence(d);
  updatePosition(d);
  updateRisk(d);
  updateTrades(d);
  updateBacktest(d);
  pushEquityPoint(d.equityPoint || d.capital, d.ts);

  const sel = $('pair-select');
  if (d.asset && sel.value !== d.asset) sel.value = d.asset;
}

/* ════════════════════════════════════════════════════════════
   WEBSOCKET
════════════════════════════════════════════════════════════ */
function setConnected(ok) {
  const dot = $('conn-dot');
  const lbl = $('conn-label');
  dot.className   = ok === true ? 'conn-dot live' : ok === false ? 'conn-dot err' : 'conn-dot';
  lbl.textContent = ok === true ? 'Live'          : ok === false ? 'Disconnected' : 'Connecting…';
  lbl.style.color = ok === true ? 'var(--green)'  : ok === false ? 'var(--red)'   : 'var(--text2)';
}

function setCtrlMsg(msg, color) {
  const el = $('ctrl-msg');
  el.textContent = msg;
  el.style.color = color || 'var(--text2)';
  if (msg) setTimeout(() => { if (el.textContent === msg) el.textContent = ''; }, 3000);
}

function send(payload) {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify(payload));
    return true;
  }
  setCtrlMsg('Not connected', 'var(--red)');
  return false;
}

function connect() {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  const url   = proto + '//' + (location.host || 'localhost:3000');
  try { ws = new WebSocket(url); } catch(e) { setConnected(null); reconnect(); return; }

  ws.onopen    = () => { setConnected(true);  setCtrlMsg('Connected', 'var(--green)'); clearTimeout(reconnTimer); };
  ws.onmessage = e => { try { update(JSON.parse(e.data)); } catch(_) {} };
  ws.onclose   = () => { setConnected(false); reconnect(); };
  ws.onerror   = () => ws.close();
}

function reconnect() {
  clearTimeout(reconnTimer);
  reconnTimer = setTimeout(connect, 3000);
}

/* ════════════════════════════════════════════════════════════
   CONTROLS
════════════════════════════════════════════════════════════ */
function initControls() {
  $('btn-start').addEventListener('click', () => {
    if (send({ cmd: 'start' })) setCtrlMsg('Starting…', 'var(--green)');
  });

  $('btn-stop').addEventListener('click', () => {
    if (send({ cmd: 'stop' })) setCtrlMsg('Stopping…', 'var(--red)');
  });

  $('pair-select').addEventListener('change', e => {
    const pair = e.target.value;
    if (pair && send({ cmd: 'setPair', pair }))
      setCtrlMsg('Switching to ' + pair + '…', 'var(--accent)');
  });

  const runBacktest = () => {
    if (send({ cmd: 'backtest' })) {
      btSnapshot = null;
      wasBacktest = false;
      $('bt-idle').style.display    = 'none';
      $('bt-running').style.display = '';
      $('bt-results').style.display = 'none';
      $('bt-meta').textContent = 'Running…';
      setCtrlMsg('Backtest started…', 'var(--accent)');
    }
  };

  $('btn-backtest').addEventListener('click', runBacktest);
  $('bt-btn').addEventListener('click', runBacktest);

  $('mode-toggle').addEventListener('click', () => {
    isLiveMode = !isLiveMode;
    $('mode-toggle').classList.toggle('on', isLiveMode);
    $('lbl-paper').classList.toggle('active', !isLiveMode);
    $('lbl-live').classList.toggle('active',   isLiveMode);
    send({ cmd: 'setMode', mode: isLiveMode ? 'live' : 'paper' });
    setCtrlMsg('Mode: ' + (isLiveMode ? 'LIVE' : 'PAPER'), isLiveMode ? 'var(--red)' : 'var(--accent)');
  });
}

function tickClock() {
  $('hdr-clock').textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
}

/* ════════════════════════════════════════════════════════════
   BOOT  (script at end of <body> — DOM fully ready)
════════════════════════════════════════════════════════════ */
initChart();
initControls();
connect();
tickClock();
setInterval(tickClock, 1000);
</script>
</body>
</html>
